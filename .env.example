# Copy this file to .env (or just set these as real environment variables
# on your server) before deploying anywhere public. None of these are
# required for local use on your own Mac — every one has a safe default
# that keeps today's local, single-user-friendly behavior unchanged.

# Encrypts connected email account passwords at rest (AES-256-GCM). If
# unset, a key is auto-generated and saved to data/.encryption_key —
# fine for local use, but set this yourself before deploying somewhere
# public so the key doesn't live in the same place as the data it protects.
# Also keep data/.encryption_key out of any synced/backed-up copy of the
# folder (iCloud/Dropbox/Time Machine): a backup of both the key and the
# encrypted account file is effectively a backup of the plaintext passwords.
ENCRYPTION_KEY=

# A single shared password required (via HTTP Basic Auth) before anyone
# can reach the app at all — an outer lock for a private beta. Leave
# unset for normal use; every real user still has their own separate
# account/login on top of this.
SITE_PASSWORD=

# Enables a developer stats page at /admin (aggregate counts only, never
# per-user data). Leave unset to keep /admin fully disabled (404).
ADMIN_PASSWORD=

# Set to "production" once you're behind a reverse proxy (nginx, an AWS
# load balancer, etc.) that terminates HTTPS. This turns on the Secure
# cookie flag and the Strict-Transport-Security header. Leave unset for
# local plain-HTTP use.
NODE_ENV=

# Email 2FA — sends the 6-digit login/signup codes. Uses Gmail SMTP by
# default: set SMTP_USER to a Gmail address and SMTP_PASS to a Gmail
# *app password* (myaccount.google.com → Security → App passwords).
# If these are unset, codes are printed to the server console (dev only).
# To use another provider (Amazon SES, etc.) later, also set SMTP_HOST/PORT.
SMTP_USER=
SMTP_PASS=
SMTP_HOST=
SMTP_PORT=
SMTP_FROM=
